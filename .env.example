# ─────────────────────────────────────────────────────────────
# Knot — environment configuration. Copy to `.env` and fill in.
#   cp .env.example .env
# Never commit your real .env (it's gitignored).
# ─────────────────────────────────────────────────────────────

# ── LLM (Anthropic by default) ───────────────────────────────
LLM_PROVIDER=anthropic                 # anthropic | openrouter | ollama
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Optional: override the small "chat" model used for small talk + tools
# CHAT_MODEL=claude-haiku-4-5-20251001

# OpenRouter (only if LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=

# Ollama (only if LLM_PROVIDER=ollama; needs `ollama serve`)
# OLLAMA_MODEL=llama3.1:8b

# ── Telegram ─────────────────────────────────────────────────
# Create a bot with @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=123456:ABC-yourTelegramBotToken

# ── Postgres (settings, drafts, checkpointer) ────────────────
DATABASE_URL=postgresql://knot:knot@localhost:5432/knot?schema=public

# ── Neo4j (knowledge graph) ──────────────────────────────────
# Local Docker: bolt://localhost:7687 | Neo4j Aura: neo4j+s://xxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me

# ── Public URL (OAuth redirects + Telegram Mini App) ─────────
# Your server's https base. In dev you can use an ngrok tunnel.
PUBLIC_URL=https://your-domain.example

# ── Google OAuth (Gmail + Calendar) ──────────────────────────
# Google Cloud Console → Credentials → OAuth client (Web).
# Enable Gmail API + Google Calendar API. Add the redirect URI below.
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx
GOOGLE_REDIRECT_URI=https://your-domain.example/auth/google/callback

# ── Microsoft OAuth (Outlook) — optional ─────────────────────
# Azure Portal → Microsoft Entra ID → App registrations.
# Delegated scopes: Mail.Read, User.Read, offline_access.
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=https://your-domain.example/auth/microsoft/callback

# ── Localization (optional) ──────────────────────────────────
TZ_DISPLAY=Asia/Kolkata                # timezone for chat date/time answers
DEFAULT_CITY=Delhi                     # default city for the weather tool
